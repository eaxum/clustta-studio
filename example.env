DATA_FOLDER=/home/server-user-name/data/
PROJECTS_FOLDER=/home/server-user-name/projects/
CLUSTTA_STUDIO_API_KEY=StudioKey
CLUSTTA_SERVER_NAME=StudioName
CLUSTTA_SERVER_URL=http://host-ip/clustta

# Database paths for user accounts and sessions
STUDIO_USERS_DB=./data/studio_users.db
SESSION_DB=./data/sessions.db

# Standalone mode (no Clustta Cloud connection).
# When true, CLUSTTA_STUDIO_API_KEY and CLUSTTA_SERVER_NAME are not required.
PRIVATE=true

# Studio integrations (Kitsu, etc.)
# Base64-encoded 32-byte AES-256-GCM key. Generate: openssl rand -base64 32
# Leave unset to disable integrations.
INTEGRATION_SECRET_KEY=

# Listener reconcile cadence (Go duration). Defaults to 30m.
INTEGRATION_RECONCILE_INTERVAL=30m

